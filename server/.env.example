# ─── Server ───────────────────────────────────────────────
NODE_ENV=development
PORT=5000

# ─── Database ─────────────────────────────────────────────
MONGO_URI=mongodb+srv://<username>:<password>@cluster.mongodb.net/merchstore

# ─── Auth (M1) ────────────────────────────────────────────
JWT_SECRET=<your_jwt_secret_key>
JWT_EXPIRES_IN=7d

#- ─── Google OAuth (M1) ─────────────────────────────────────
GOOGLE_CLIENT_ID=<your_google_client_id>
GOOGLE_CLIENT_SECRET=<your_google_client_secret>
GOOGLE_CALLBACK_URL=http://localhost:5000/api/auth/google/callback

# ─── Cloudinary (M1) ──────────────────────────────────────
CLOUDINARY_CLOUD_NAME=<your_cloudinary_cloud_name>
CLOUDINARY_API_KEY=<your_cloudinary_api_key>
CLOUDINARY_API_SECRET=<your_cloudinary_api_secret>

# ─── Stripe (M2) ──────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_<your_stripe_secret_key>
STRIPE_WEBHOOK_SECRET=whsec_<your_stripe_webhook_secret>

# ─── Email / SMTP (M2) ────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=merch@geetauniversity.ac.in
SMTP_PASS=<google_app_password>
ALERT_EMAIL=admin@geetauniversity.ac.in

# ─── Inventory Cron (M2) ──────────────────────────────────
LOW_STOCK_THRESHOLD=10
CRON_SCHEDULE="0 8 * * *"

# ─── Rate Limiting ────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100
ORDER_RATE_LIMIT_MAX=10
ORDER_RATE_LIMIT_WINDOW_MS=60000

# ─── Client URL ───────────────────────────────────────────
CLIENT_URL=http://localhost:5173
